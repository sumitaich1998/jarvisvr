# JarvisVR voice-service configuration (copy to .env; values shown are defaults).
# Everything has a safe offline fallback, so an empty .env still runs headless.

# --- Backend bridge ---------------------------------------------------------
# WebSocket endpoint of the agent-backend (see docs/PROTOCOL.md).
JARVIS_BACKEND_URL=ws://localhost:8765/jarvis
# Optional parallel raw-audio PCM16 channel (not required for JSON transcripts).
JARVIS_AUDIO_URL=ws://localhost:8765/audio
JARVIS_LOCALE=en-US

# --- Engine selection -------------------------------------------------------
# wake: auto | openwakeword | porcupine | energy
JARVIS_WAKE=auto
# stt:  auto | faster-whisper | vosk | mock
JARVIS_STT=auto
# tts:  auto | piper | pyttsx3 | mock
JARVIS_TTS=auto
# "auto" tries the preferred real engine, then falls back to the offline option.

# --- Audio framing ----------------------------------------------------------
JARVIS_SAMPLE_RATE=16000
JARVIS_FRAME_MS=30
# Optional input/output device index (sounddevice). Blank = system default.
JARVIS_INPUT_DEVICE=
JARVIS_OUTPUT_DEVICE=

# --- Wake word --------------------------------------------------------------
JARVIS_WAKE_WORD=jarvis
JARVIS_WAKE_THRESHOLD=0.5
# openwakeword model name (built-in "hey_jarvis") or a path to a .onnx/.tflite.
JARVIS_OWW_MODEL=hey_jarvis
# Porcupine (cloud-issued access key required; "jarvis" is a built-in keyword).
JARVIS_PORCUPINE_ACCESS_KEY=
JARVIS_PORCUPINE_KEYWORD=jarvis
# EnergyFallback tuning (RMS over int16; approximates speech onset, not the word).
JARVIS_WAKE_ENERGY_THRESHOLD=1000
JARVIS_WAKE_MIN_FRAMES=3

# --- Endpointing (VAD) ------------------------------------------------------
JARVIS_VAD_THRESHOLD=300
JARVIS_SILENCE_MS=800
JARVIS_MAX_UTTERANCE_MS=12000
JARVIS_WAKE_GRACE_MS=3000

# --- STT engines ------------------------------------------------------------
# faster-whisper: model size (tiny.en, base.en, small.en, medium, large-v3) or path.
JARVIS_WHISPER_MODEL=base.en
JARVIS_WHISPER_DEVICE=cpu
JARVIS_WHISPER_COMPUTE_TYPE=int8
JARVIS_STT_LANGUAGE=en
# vosk: path to an unpacked model directory.
JARVIS_VOSK_MODEL=
# MockSTT canned transcript (used by the offline fallback + demos/tests).
JARVIS_MOCK_TRANSCRIPT=jarvis what is the weather in tokyo

# --- TTS engines ------------------------------------------------------------
# piper: path to a voice .onnx (its .onnx.json is auto-detected next to it).
JARVIS_PIPER_MODEL=
JARVIS_PIPER_CONFIG=
# pyttsx3 voice id / rate (optional).
JARVIS_PYTTSX3_VOICE=
JARVIS_PYTTSX3_RATE=

# --- Multi-language (best-effort hooks for the agent's translation feature) --
# STT language ("" / "auto" => Whisper autodetect). TTS language is engine-dependent.
JARVIS_STT_LANGUAGE=en
JARVIS_TTS_LANGUAGE=

# --- Continuous ambient listening (v1.1 Multimodal Perception) --------------
# auto = listen only when the backend sends perception.request{ambient_audio,start};
# on   = autostart at connect; off = disabled (won't advertise/serve ambient_audio).
JARVIS_AMBIENT=auto
# One perception.audio_scene per window of room audio.
JARVIS_AMBIENT_WINDOW_MS=4000
# Speaker tag for overheard speech (not directed at Jarvis): user | other | unknown.
JARVIS_AMBIENT_SPEAKER=other
# Fraction of voiced frames in a window to consider speech present (then transcribe).
JARVIS_AMBIENT_MIN_SPEECH_RATIO=0.25

# --- Sound-event detection (v1.1) -------------------------------------------
# auto | yamnet (extra: sound-yamnet) | heuristic | off
JARVIS_SOUND_EVENTS=auto
JARVIS_SOUND_EVENT_THRESHOLD=0.5
JARVIS_SOUND_EVENT_WINDOW_MS=1000

# --- Barge-in (interrupt TTS when the user starts talking) ------------------
JARVIS_BARGE_IN=true
JARVIS_BARGE_IN_THRESHOLD=1500
JARVIS_BARGE_IN_MIN_FRAMES=3

# --- Logging ----------------------------------------------------------------
JARVIS_LOG_LEVEL=INFO
