{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvisvr.dev/schema/perception.vision_frame.schema.json",
  "title": "perception.vision_frame payload",
  "description": "PROTOCOL.md §8.4 — a passthrough RGB camera frame + camera pose. On /vision this object is the binary header (without data, transport=binary).",
  "type": "object",
  "required": ["frame_id", "camera", "format"],
  "properties": {
    "frame_id": { "type": "string", "minLength": 1 },
    "camera": { "$ref": "common.schema.json#/$defs/camera" },
    "format": { "$ref": "common.schema.json#/$defs/vision_format" },
    "width": { "type": "integer", "minimum": 1 },
    "height": { "type": "integer", "minimum": 1 },
    "quality": { "type": "integer", "minimum": 1, "maximum": 100 },
    "transport": { "type": "string", "enum": ["inline", "binary"] },
    "data": { "description": "Base64 image bytes; present iff transport=inline.", "type": "string" },
    "seq": { "type": "integer", "minimum": 0 },
    "ts_capture": { "type": "integer", "minimum": 0 },
    "pose": { "$ref": "common.schema.json#/$defs/pose" },
    "intrinsics": {
      "type": "object",
      "properties": {
        "fx": { "type": "number" },
        "fy": { "type": "number" },
        "cx": { "type": "number" },
        "cy": { "type": "number" }
      }
    }
  }
}
