{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvisvr.dev/schema/server.agent_info.schema.json",
  "title": "server.agent_info payload",
  "description": "PROTOCOL.md §10.1 — an agent's persona/skills/tools/memory (reply to client.agent_inspect). v1.3.",
  "type": "object",
  "required": ["role", "name"],
  "properties": {
    "role": { "type": "string", "minLength": 1 },
    "name": { "type": "string" },
    "source": { "type": "string", "enum": ["builtin", "user"] },
    "persona": { "type": "string" },
    "tools": { "type": "array", "items": { "type": "string" } },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "source": { "type": "string", "enum": ["builtin", "user"] }
        }
      }
    },
    "memory": {
      "type": "object",
      "properties": {
        "summary": { "type": "string" },
        "items": { "type": "integer", "minimum": 0 },
        "recent": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["ts", "text"],
            "properties": {
              "ts": { "type": "integer", "minimum": 0 },
              "text": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
