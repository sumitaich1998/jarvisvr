# ---------------------------------------------------------------------------
# JarvisVR agent-backend configuration (copy to `.env` and edit as needed).
# Every value has a safe default; the server runs fully offline with no keys.
# ---------------------------------------------------------------------------

# --- WebSocket server -------------------------------------------------------
JARVIS_HOST=0.0.0.0
JARVIS_PORT=8765
JARVIS_WS_PATH=/jarvis

# --- LLM provider (universal, multi-provider) -------------------------------
# Tip: run `jarvis-backend setup` to configure this interactively (it asks for
# your API key, masked) and writes this file for you (chmod 600).
#
# JARVIS_LLM picks the provider id. `mock` is deterministic and needs NO key
# (the default, demoable offline). Any other id needs that provider's key; if a
# key/SDK is missing the server logs a warning and falls back to `mock` — never
# crashes. Run `jarvis-backend providers` to list them all.
#
# Supported ids: mock | openai | anthropic | gemini | vertex | azure | bedrock |
#   mistral | cohere | groq | together | openrouter | deepseek | xai |
#   perplexity | fireworks | ollama | lmstudio | vllm | custom
JARVIS_LLM=mock

# Generic overrides (apply to the active provider):
# JARVIS_MODEL=                      # model name (else the provider default)
# JARVIS_LLM_BASE_URL=               # custom/self-hosted OpenAI-compatible base URL
# JARVIS_LLM_API_KEY=                # generic key fallback (for custom/local providers)
# JARVIS_USE_LITELLM=0               # 1 = route everything through LiteLLM ([providers] extra)

# Per-provider model overrides (optional; else the registry default is used):
JARVIS_OPENAI_MODEL=gpt-4o-mini
JARVIS_ANTHROPIC_MODEL=claude-3-5-sonnet-latest
# JARVIS_GEMINI_MODEL=gemini-1.5-flash
# JARVIS_GROQ_MODEL=llama-3.3-70b-versatile
# JARVIS_OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Provider API keys (set ONLY the one(s) you use; leave blank for mock) ---
# Native SDK paths (pip install '.[openai]' / '.[anthropic]'):
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# OpenAI-compatible over plain httpx (no extra SDK needed):
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=
PERPLEXITY_API_KEY=
FIREWORKS_API_KEY=
# Routed via LiteLLM (pip install '.[providers]'):
# AZURE_API_KEY=
# COHERE_API_KEY=
# (Bedrock uses AWS credentials; Vertex uses Google ADC — no key var.)

# --- Perception (v1.1 multimodal: sight / hearing / gaze) -------------------
# Which provider "sees" passthrough camera frames: mock | openai | anthropic.
# `mock` synthesizes a deterministic scene description offline (no key needed);
# openai/anthropic send real image content blocks to the vision-capable model.
JARVIS_VISION=mock
# Master switch for perception (vision/audio/gaze correlation + tools).
JARVIS_PERCEPTION=1
# Proactive observations on notable sounds (doorbell, alarm…). Opt-in (privacy).
JARVIS_PROACTIVE=0
# Default frames-per-second requested when Jarvis turns the camera on.
JARVIS_VISION_FPS=2
# How many recent frames to keep in the rolling perception buffer.
JARVIS_VISION_BUFFER=8

# --- Multi-agent orchestration (v1.2 §9) ------------------------------------
# Jarvis decomposes each goal and delegates to skill-specialized agents.
# 1 = on (default; a trivial goal yields a 1-agent plan). 0 = single-agent loop.
JARVIS_ORCHESTRATION=1
# Where Agent Skills (agentskills.io SKILL.md) live. Missing dir is fine —
# agents fall back to built-in tool mappings. Default: <repo>/skills.
# This is ALSO the root where in-headset–authored skills (§10.2) are written
# (under <category>/<name>/SKILL.md with metadata.source: user).
JARVIS_SKILLS_DIR=../skills

# --- Tracing & in-headset authoring (v1.3 §10) ------------------------------
# Record a per-turn trace of everything each agent does (memory reads/writes,
# skill activations, tool calls, delegations). Secrets are never traced. Live
# streaming is gated by client.trace_subscribe (off until the trace view opens).
JARVIS_TRACE=1
# (User-authored agents persist to JARVIS_DATA_DIR/user_agents.json.)

# --- Holograms --------------------------------------------------------------
# Path to the canonical widget catalog published by holo-tools/. If the file is
# absent (e.g. holo-tools is still being built), a built-in fallback catalog is
# used so the backend is never blocked.
JARVIS_HOLO_REGISTRY=../holo-tools/registry.json

# --- Tools ------------------------------------------------------------------
# Optional real weather API key. Without it, get_weather returns deterministic
# mock data so demos still work.
JARVIS_WEATHER_API_KEY=

# --- Memory / storage -------------------------------------------------------
# Directory for the long-term JSON key/value store (notes, reminders, etc.).
JARVIS_DATA_DIR=.data

# --- Agent behaviour --------------------------------------------------------
# Max plan -> tool -> observe iterations per user turn (safety bound).
JARVIS_MAX_STEPS=6

# --- Logging ----------------------------------------------------------------
JARVIS_LOG_LEVEL=INFO
# Set to 1 to emit one-line JSON logs (useful in Docker / aggregation).
JARVIS_LOG_JSON=0
