# JarvisVR infra environment — copy to infra/.env and fill in.
#   cp .env.example .env
# .env is git-ignored (it may hold secrets). docker compose reads it via env_file,
# passing these variables into the agent-backend and voice-service containers.
#
# Each service is the source of truth for its own variables — see
# agent-backend/.env.example and voice-service/.env.example for the full lists.
# The variables below are the common ones, using the names the services actually read.

# ---- agent-backend (the brain) ------------------------------------------
JARVIS_HOST=0.0.0.0
JARVIS_PORT=8765
JARVIS_WS_PATH=/jarvis
JARVIS_LOG_LEVEL=INFO

# LLM provider id: mock | openai | anthropic | gemini | groq | ollama | … (20+).
# `mock` runs fully offline with no key. Tip: `jarvis-backend setup` writes these
# for you; run `jarvis-backend providers` for the full list.
JARVIS_LLM=mock

# Provider API keys — set ONLY the one(s) you use (leave blank for mock):
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Generic fallbacks for custom / local / OpenAI-compatible providers:
# JARVIS_LLM_API_KEY=
# JARVIS_LLM_BASE_URL=
# JARVIS_USE_LITELLM=0          # 1 = route everything via the LiteLLM universal adapter

# Path to the holo-tools registry (optional; auto-discovered at the repo path if mounted):
JARVIS_HOLO_REGISTRY=/holo-tools/registry.json

# v1.1 perception — which provider "sees" frames (mock = deterministic offline):
JARVIS_VISION=mock
# JARVIS_PERCEPTION=1

# ---- voice-service (ears & mouth) ---------------------------------------
# How voice-service reaches the brain over the compose network:
JARVIS_BACKEND_URL=ws://agent-backend:8765/jarvis
# Engine selection — `auto` prefers a real engine then falls back; `mock`/`energy`
# stay fully offline. See voice-service/.env.example for all options.
JARVIS_WAKE=energy
JARVIS_STT=mock
JARVIS_TTS=mock
